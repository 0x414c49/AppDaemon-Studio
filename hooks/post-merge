#!/bin/bash
#
# Post-merge hook to auto-install pre-commit hooks
# This runs after git pull or merge
#

HOOKS_SOURCE="hooks/pre-commit"
HOOKS_DEST=".git/hooks/pre-commit"

if [ -f "$HOOKS_SOURCE" ]; then
    echo "Installing pre-commit hooks..."
    cp "$HOOKS_SOURCE" "$HOOKS_DEST"
    chmod +x "$HOOKS_DEST"
    echo "✓ Pre-commit hooks installed successfully"
fi
